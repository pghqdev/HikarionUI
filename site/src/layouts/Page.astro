---
import { TABS } from "../nav.mjs";
import { ASSET_V } from "../assets.mjs";

const { title, description } = Astro.props;
const BASE = import.meta.env.BASE_URL; // ends with "/"
const themes = ["auto", "light", "dark", "nord", "dracula", "catppuccin"];
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
// Crawlers do not resolve relative og:image, so this one has to be absolute.
const ogImage = Astro.site ? new URL(`${BASE}og.png`, Astro.site).href : `${BASE}og.png`;
const here = Astro.url.pathname.slice(BASE.length);
const active = (t) => (t.match ? here.startsWith(t.match) : here.replace(/\/$/, "") === t.href);
const full = `${title} — Hikarion UI`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{full}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hikarion UI" />
    <meta property="og:title" content={full} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Hikarion UI — bare HTML, quietly tasteful." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="color-scheme" content="light dark" />
    <link rel="alternate" type="text/plain" href={`${BASE}llms.txt`} title="llms.txt" />
    <!-- No-FOUC: apply the saved theme before first paint. -->
    <script is:inline>
      try { var t = localStorage.getItem("hikarion-theme"); if (t) document.documentElement.dataset.theme = t; } catch (e) {}
    </script>
    <link rel="stylesheet" href={`${BASE}hikarion.min.css?v=${ASSET_V}`} />
    <link rel="stylesheet" href={`${BASE}themes/nord.css?v=${ASSET_V}`} />
    <link rel="stylesheet" href={`${BASE}themes/dracula.css?v=${ASSET_V}`} />
    <link rel="stylesheet" href={`${BASE}themes/catppuccin.css?v=${ASSET_V}`} />
    <script src={`${BASE}hikarion.js?v=${ASSET_V}`} defer></script>

    <style is:global>
      /* Reserve the scrollbar on every page, so navigating from a short page to
         a scrolling one does not shift the centred column sideways. */
      html { scrollbar-gutter: stable; }
      body { max-width: 72rem; margin-inline: auto; }
      .bar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); flex-wrap: wrap; }
      .switch { display: inline-flex; gap: var(--space-1); flex-wrap: wrap; }
      .switch button[aria-pressed="true"] { color: var(--accent); border-color: color-mix(in oklch, var(--accent) 45%, var(--border)); }
      .tabs { display: flex; gap: var(--space-4); flex-wrap: wrap; border-block-end: 1px solid var(--line); margin-block: var(--space-4) var(--space-6); }
      .tabs a { padding-block: var(--space-2); text-decoration: none; color: var(--muted); border-block-end: 2px solid transparent; margin-block-end: -1px; }
      .tabs a:hover { color: var(--fg); }
      .tabs a[aria-current="page"] { color: var(--fg); border-block-end-color: var(--accent); }
      .lede { color: var(--muted); max-width: 62ch; }
      .grid { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
      .row { display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center; }
      footer { color: var(--muted); border-top: 1px solid var(--line); margin-block-start: var(--space-8); padding-block: var(--space-7); }

      /* Two- or three-column documentation shell: nav rail, prose, on-page ToC.
         Sized to fit the same 72rem body every other page uses — a wider
         container here would shift the header and tabs on every navigation. */
      .doc { display: grid; grid-template-columns: 13rem minmax(0, 1fr) 11rem; gap: var(--space-6); align-items: start; }
      .doc[data-cols="2"] { grid-template-columns: 15rem minmax(0, 1fr); }
      .doc .side, .doc .toc { position: sticky; top: var(--space-5); font-size: 0.9rem; max-block-size: calc(100dvh - var(--space-7)); overflow-y: auto; }
      .doc nav ul { list-style: none; padding: 0; margin: 0 0 var(--space-5); display: grid; gap: var(--space-1); }
      .doc nav h6 { color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.72rem; margin-block: var(--space-4) var(--space-2); }
      .doc nav a { text-decoration: none; color: var(--muted); display: block; padding-block: 2px; }
      .doc nav a:hover { color: var(--fg); }
      .doc nav a[aria-current="page"] { color: var(--accent); }
      .prose { max-width: 44rem; }
      /* Live example above its snippet. Contained, because the examples include
         overlays and sticky things that would otherwise escape into the page. */
      [data-preview] {
        contain: paint;
        border: 1px solid var(--line);
        border-radius: var(--radius) var(--radius) 0 0;
        border-block-end: none;
        padding: var(--space-6);
        background: var(--bg);
        overflow-x: auto;
      }
      [data-preview] + pre { border-start-start-radius: 0; border-start-end-radius: 0; }
      [data-preview] > :first-child { margin-block-start: 0; }
      [data-preview] > :last-child { margin-block-end: 0; }
      .prose table { display: block; overflow-x: auto; }
      @media (max-width: 64rem) {
        .doc, .doc[data-cols="2"] { grid-template-columns: 1fr; }
        .doc .side, .doc .toc { position: static; max-block-size: none; }
        .doc .toc { display: none; }
      }
    </style>
    <slot name="head" />
  </head>

  <body>
    <header class="bar">
      <a href={BASE} style="text-decoration:none"
        ><strong style="font-size:1.1rem">Hikarion<span style="color:var(--accent)">UI</span></strong></a
      >
      <nav class="switch" aria-label="Theme">
        {themes.map((t) => <button data-set-theme={t}>{t[0].toUpperCase() + t.slice(1)}</button>)}
      </nav>
    </header>

    <nav class="tabs" aria-label="Sections">
      {TABS.map((t) => (
        <a href={BASE + t.href} aria-current={active(t) ? "page" : undefined}>{t.label}</a>
      ))}
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        Hikarion UI — <a href="https://github.com/pghqdev/HikarionUI">source</a> ·
        <a href={`${BASE}llms.txt`}>llms.txt</a> ·
        <a href={`${BASE}hikarion-rules.md`}>agent rules</a>.
        Minimalistic. Tasteful. Snappy.
      </p>
    </footer>
  </body>
</html>
