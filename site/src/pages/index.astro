---
import Page from "../layouts/Page.astro";

const BASE = import.meta.env.BASE_URL;
const install = `<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/hikarion-ui/dist/hikarion.min.css">
<script src="https://cdn.jsdelivr.net/npm/hikarion-ui/dist/hikarion.js" defer></${"script"}>`;

const description =
  "A class-light CSS framework for semantic HTML. Bare tags look great; ~20 tokens are a theme; a data-* vocabulary adds variants.";

// Marked up for search and answer engines: what the thing is, what it costs,
// what it runs on. Same facts as the copy below, in a form a crawler can read.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Hikarion UI",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  description,
  url: Astro.site?.href,
  license: "https://opensource.org/licenses/MIT",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  softwareVersion: "0.1.0",
  programmingLanguage: "CSS",
};
---

<Page title="Tasteful CSS for semantic HTML" description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="hero">
    <span data-badge data-variant="accent">v0.1 · class-light CSS</span>
    <h1>Bare HTML, quietly tasteful.</h1>
    <p class="lede">
      A class-light CSS framework for semantic HTML. Bare tags look great with
      no classes; a small <code>data-*</code> vocabulary adds variants; a
      <code>data-theme</code> container re-lights the whole page — shadows and
      all — from ~20 tokens.
    </p>
    <div class="row" style="margin-block-start:var(--space-6)">
      <a href={`${BASE}docs/installation`}><button data-variant="solid">Get started</button></a>
      <button onclick="Hikarion.toast('Copied the install snippet', {variant:'success'}); navigator.clipboard?.writeText(document.getElementById('snippet').innerText)">Copy install</button>
      <a href="https://github.com/pghqdev/HikarionUI"><button>GitHub</button></a>
    </div>
    <pre style="margin-block-start:var(--space-6)"><code id="snippet">{install}</code></pre>
  </section>

  <h2>Components</h2>
  <p>Every element below is bare semantic HTML — the only attributes are Hikarion's <code>data-*</code> hooks. Switch the theme above; it all re-lights. The <a href={`${BASE}components`}>full reference</a> has the rest.</p>

  <div class="grid">
    <article>
      <h3>Buttons</h3>
      <div class="row">
        <button>Default</button>
        <button data-variant="solid">Primary</button>
        <button data-variant="danger solid">Delete</button>
      </div>
    </article>

    <article>
      <h3>Badges &amp; chips</h3>
      <div class="row">
        <span data-badge>Neutral</span>
        <span data-badge data-variant="success">Passing</span>
        <span data-badge data-variant="danger solid">3 errors</span>
      </div>
      <div class="row" style="margin-block-start:var(--space-4)">
        <button data-chip aria-pressed="true">All</button>
        <button data-chip aria-pressed="false">Open</button>
        <span data-chip>filter.css <button data-chip-remove aria-label="Remove">✕</button></span>
      </div>
    </article>

    <article>
      <h3>Form</h3>
      <label for="email">Email</label>
      <input id="email" type="email" required placeholder="you@example.com" />
      <p><small>Type an invalid address and blur — native <code>:user-invalid</code>.</small></p>
    </article>

    <article>
      <h3>Dropdown</h3>
      <button popovertarget="menu">Actions</button>
      <div id="menu" popover data-menu>
        <button>Edit</button>
        <a href="#">Share</a>
        <hr />
        <button>Delete</button>
      </div>
    </article>
  </div>

  <div role="status" data-variant="success" style="margin-block-start:var(--space-6)"><strong>Saved</strong> — every status colour is Tier-1 and passes 4.5:1 contrast in every theme.</div>

  <details style="margin-block-start:var(--space-6)">
    <summary>What does Hikarion deliberately not do?</summary>
    <p>No utility classes, no JS framework, no build step for you. It styles pages you own; it yields to any pre-existing site CSS by design.</p>
  </details>

  <h2>Start here</h2>
  <div class="grid">
    <article>
      <h3><a href={`${BASE}docs/installation`}>Installation</a></h3>
      <p>One <code>&lt;link&gt;</code>, or one <code>bun add</code>. No build step, no config.</p>
    </article>
    <article>
      <h3><a href={`${BASE}components`}>Component reference</a></h3>
      <p>Every hook, its markup contract, usage and accessibility notes — the same file coding agents are given.</p>
    </article>
    <article>
      <h3><a href={`${BASE}playground`}>Playground</a></h3>
      <p>Drag three Tier-1 tokens and watch the spacing, radius and shadow scales re-derive live.</p>
    </article>
    <article>
      <h3><a href={`${BASE}examples`}>Examples</a></h3>
      <p>A dashboard, a settings page and an auth screen, built only from documented vocabulary.</p>
    </article>
    <article>
      <h3><a href={`${BASE}docs/theming`}>Theming</a></h3>
      <p>Nineteen custom properties are a theme. Everything else derives.</p>
    </article>
    <article>
      <h3><a href={`${BASE}agents`}>For agents</a></h3>
      <p><code>llms.txt</code>, the rules file, an installable skill, and a markup validator.</p>
    </article>
  </div>

  <style>
    .hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-block: var(--space-6) var(--space-4); }
    .hero p.lede { font-size: 1.25rem; color: var(--muted); max-width: 44ch; }
  </style>
</Page>
