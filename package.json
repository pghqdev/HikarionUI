{
  "name": "hikarion-ui",
  "version": "0.1.0",
  "description": "Class-light CSS framework for semantic HTML. Bare tags look great; ~20 tokens are a theme.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pghqdev/HikarionUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pghqdev/HikarionUI.git"
  },
  "bugs": "https://github.com/pghqdev/HikarionUI/issues",
  "keywords": [
    "css",
    "css-framework",
    "semantic-html",
    "classless",
    "class-light",
    "design-tokens",
    "theme",
    "oklch",
    "dark-mode",
    "agent"
  ],
  "main": "dist/hikarion.min.css",
  "style": "dist/hikarion.css",
  "jsdelivr": "dist/hikarion.min.css",
  "unpkg": "dist/hikarion.min.css",
  "types": "src/hikarion.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "rules",
    "skills.sh",
    "src/hikarion.d.ts"
  ],
  "exports": {
    ".": "./dist/hikarion.css",
    "./min": "./dist/hikarion.min.css",
    "./js": {
      "types": "./src/hikarion.d.ts",
      "default": "./dist/hikarion.js"
    },
    "./themes/*": "./dist/themes/*.css",
    "./rules": "./rules/hikarion-rules.md",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "mkdir -p dist && (cd dist && lightningcss --bundle --sourcemap ../src/hikarion.css -o hikarion.css && lightningcss --bundle --minify --sourcemap ../src/hikarion.css -o hikarion.min.css) && cp src/hikarion.js dist/hikarion.js && bun scripts/build-themes.mjs && bun scripts/build-rules.mjs && bun scripts/cdn-docs.mjs",
    "build:rules": "bun scripts/build-rules.mjs",
    "build:themes": "bun scripts/build-themes.mjs",
    "check": "bun scripts/contrast-check.mjs",
    "check:size": "bun scripts/bundle-size.mjs",
    "check:a11y": "bun scripts/a11y-check.mjs",
    "check:markup": "bun scripts/validate-markup.mjs",
    "check:visual": "bun scripts/visual-check.mjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "ci": "bun run typecheck && bun test && bun run check && bun run lint:css && bun run check:markup && bun run build && bun run check:size && bun run check:a11y && bun run check:visual",
    "prepublishOnly": "bun run ci"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@types/node": "^22.15.21",
    "lightningcss-cli": "^1.30.1",
    "playwright": "^1.52.0",
    "stylelint": "^16.20.0",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "^5.8.3"
  }
}
